# Copy to .env and set values for your environment.
# This file is safe to commit; do not commit .env with real secrets.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- PC-Ops Orchestrator Server ----
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-in-production
FLASK_CONFIG=production

# Database (PostgreSQL for production)
POSTGRES_USER=pcops
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pcops

# Agent API Keys (comma-separated, used by PowerShell agent)
AGENT_API_KEYS=your-agent-key-1,your-agent-key-2

# Port configuration
SERVER_PORT=5000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
