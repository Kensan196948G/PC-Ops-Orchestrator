# PC-Ops Orchestrator — 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# このファイル (.env.example) は Git 管理対象です。.env は管理対象外。
#
# Copy this file to .env and fill in the actual values.
# This file is safe to commit; never commit .env with real secrets.

# ── Claude / AI API ───────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Flask 設定 ────────────────────────────────────────
# 本番: production / 開発: development / テスト: testing
FLASK_CONFIG=production

# JWT / セッション署名鍵 (32 文字以上のランダム文字列を推奨)
# 生成例: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-in-production

# JWT トークン有効期限 (秒, デフォルト: 86400 = 24時間)
JWT_EXPIRY_SECONDS=86400

# ── データベース ──────────────────────────────────────
# SQLite (開発・テスト用)
# DATABASE_URL=sqlite:///./pc_ops.db

# PostgreSQL (本番推奨)
# DATABASE_URL=postgresql://pcops:changeme@localhost:5432/pcops
POSTGRES_USER=pcops
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pcops

# ── エージェント認証 ──────────────────────────────────
# PowerShell エージェントが使用する API キー (カンマ区切りで複数指定可)
# 生成例: python3 -c "import secrets; print(secrets.token_hex(24))"
AGENT_API_KEYS=your-agent-key-1,your-agent-key-2

# ── CORS ─────────────────────────────────────────────
# 許可するオリジン (カンマ区切り, 本番は実際のドメインを指定)
CORS_ORIGINS=http://localhost:5300,https://your-domain.example.com

# ── Security Headers ─────────────────────────────────
# Content-Security-Policy (省略時はデフォルト設定が使用される)
# CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' https://cdn.jsdelivr.net;

# ── Swagger / OpenAPI ─────────────────────────────────
# 本番は false 推奨 (true にするとドキュメントエンドポイントが公開される)
SWAGGER_ENABLED=false

# ── 通知設定 ─────────────────────────────────────────
# Slack Webhook URL
SLACK_WEBHOOK_URL=

# Microsoft Teams Webhook URL
TEAMS_WEBHOOK_URL=

# メール (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.example.com

# ── ポート設定 ───────────────────────────────────────
SERVER_PORT=5300
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
